# Copy this file to .env and fill in your values
# cp .env.example .env

# SQLite (default — no server needed)
DATABASE_URL=sqlite:////absolute/path/to/uk-stock-intelligence/ukstocks.db

# Switch to PostgreSQL later:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ukstocks

# Anthropic API key — get from https://console.anthropic.com
# Used for plain-English stock explanations (optional — falls back to template text)
ANTHROPIC_API_KEY=your_key_here

# Path to saved XGBoost model (relative to project root)
MODEL_PATH=models/xgboost_model.pkl
